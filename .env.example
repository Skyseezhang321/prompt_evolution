# Copy this file to .env and fill in the real robot webhook.
WECOM_BOT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY
WECOM_NOTIFY_ENABLED=true

# OpenAI official API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5
OPENAI_MODELS=gpt-5.5,gpt-5.5-pro,gpt-5.4,gpt-5.4-pro,gpt-5.4-mini,gpt-5.4-nano
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_OUTPUT_TOKENS=512
OPENAI_REASONING_EFFORT=none
OPENAI_TEXT_VERBOSITY=low

# OpenRouter API
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_MODELS=deepseek/deepseek-v4-pro,qwen/qwen3.7-max,z-ai/glm-5.1,minimax/minimax-m3,moonshotai/kimi-k2.6
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_MAX_TOKENS=512
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Prompt Evolution

# Optional source collection helpers
BRAVE_SEARCH_API_KEY=
X_BEARER_TOKEN=
REDDIT_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=prompt-evolution-source-collector/0.1
STACKEXCHANGE_KEY=
SOURCE_SEARCH_USER_AGENT=prompt-evolution-source-collector/0.1
SOURCE_SEARCH_TIMEOUT_SECONDS=20
