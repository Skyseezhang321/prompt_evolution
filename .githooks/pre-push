#!/bin/sh

remote_name="$1"
remote_url="$2"

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$repo_root" || exit 0

tmp_file="${TMPDIR:-/tmp}/prompt_evolution_push_$$.txt"
log_file="$repo_root/.git/wecom_notify.log"
cat > "$tmp_file"

(
    cd "$repo_root" || exit 0

    if command -v python >/dev/null 2>&1; then
        python scripts/git_wecom_notify.py watch-push \
            --remote "$remote_name" \
            --url "$remote_url" \
            --updates-file "$tmp_file"
    elif command -v py >/dev/null 2>&1; then
        py -3 scripts/git_wecom_notify.py watch-push \
            --remote "$remote_name" \
            --url "$remote_url" \
            --updates-file "$tmp_file"
    else
        exit 0
    fi

    rm -f "$tmp_file"
) >> "$log_file" 2>&1 &

exit 0
